# VolleyHub (v2) — variables de entorno

# --- Base de datos (Postgres) ---
# Conexión a Postgres. v2 crea sus propias tablas (prefijo vh_) y siembra
# datos demo la primera vez. Puede reusar el mismo Postgres del app de
# producción sin chocar, o apuntar a una base nueva.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Opcional: cadena con pooling (PgBouncer). Si se define, tiene prioridad.
DATABASE_URL_POOLED=""

# --- Autenticación de clientes ---
# Secreto HMAC para firmar las cookies de sesión de clientes (volleyv2_client).
# Genera uno con: openssl rand -hex 32
# REQUERIDO en producción — sin esto las sesiones no son seguras.
CLIENT_SESSION_SECRET="cambia-esto-por-un-secreto-seguro-de-32-bytes"

# Copiar a .env.local para desarrollo local.
# En Vercel: definir en Project Settings -> Environment Variables.
