DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DATABASE_URL_POOLED=""
# Tras conectar Postgres: npm run db:migrate (Railway ejecuta releaseCommand en railway.toml).

# --- Superficie del deploy (Vercel) ---
# public  → proyecto website (bloquea /admin y /api/admin)
# admin   → proyecto panel de administración
# Omitir en dev local para servir ambas superficies en localhost.
# NEXT_PUBLIC_APP_SURFACE=public
# NEXT_PUBLIC_APP_SURFACE=admin

# Solo en el proyecto ADMIN de Vercel (no en el público):
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Solo en el proyecto PÚBLICO de Vercel (recomendado si admin está en otro dominio):
# URL base del admin sin barra final. Ejemplo: https://admin.tudominio.com
# Sin esto en surface=public, no se muestran enlaces al panel desde el sitio público.
# NEXT_PUBLIC_ADMIN_APP_URL=https://admin.tudominio.com

# Copiar a .env.local para desarrollo local (opcional).
# En Vercel/Railway: definir solo las que apliquen en Project Settings → Environment Variables.
# Guía completa del split: docs/DEPLOY_SPLIT.md

# Resend: envío de constancia PDF tras registro de club (/equipo).
# RESEND_API_KEY=
# RESEND_FROM=noreply@tudominio.com
# Copia oculta al organizador (mismo valor que puedes guardar al crear el IT maestro). Opcional.
# ORGANIZER_BCC=tu@gmail.com
